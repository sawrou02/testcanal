generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite ne supporte pas les `enum` Prisma. Les champs ci-dessous sont
// donc des `String` dont les valeurs autorisées sont contrôlées côté
// application (DTO class-validator + constantes common/enums). Les valeurs
// possibles sont rappelées en commentaire au-dessus de chaque champ.

model User {
  id           String   @id @default(cuid())
  nom          String
  prenom       String
  email        String   @unique
  passwordHash String
  // Role: SUPER_ADMIN | ADMIN | MANAGER | COMPTABLE | LOGISTICIEN | COMMERCIAL | VENDEUR
  role         String
  pdvId        String?
  // Statut: ACTIF | INACTIF
  statut       String   @default("ACTIF")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pdv               PDV?             @relation(fields: [pdvId], references: [id])
  encaissements     Encaissement[]
  versementsValides Versement[]      @relation("ValideParVersement")
  retraitsValides   Retrait[]        @relation("ValideParRetrait")
  rapports          RapportActivite[]
  auditLogs         AuditLog[]
}

model Secteur {
  id        String     @id @default(cuid())
  nom       String
  localites Localite[]
  pdvs      PDV[]
}

model Localite {
  id        String  @id @default(cuid())
  nom       String
  secteurId String
  secteur   Secteur @relation(fields: [secteurId], references: [id])
  pdvs      PDV[]
}

model PDV {
  id           String   @id @default(cuid())
  code         String   @unique
  raisonSociale String
  // PDVType: BOUTIQUE_PROPRE | SOUS_RESEAU | AGENCE_PRINCIPALE | VAD | APPORTEUR
  type         String
  secteurId    String
  localiteId   String
  caution      Float    @default(0)
  soldeActuel  Float    @default(0)
  // Statut: ACTIF | INACTIF
  statut       String   @default("ACTIF")
  createdAt    DateTime @default(now())

  secteur       Secteur        @relation(fields: [secteurId], references: [id])
  localite      Localite       @relation(fields: [localiteId], references: [id])
  users         User[]
  abonnes       Abonne[]
  encaissements Encaissement[]
  versements    Versement[]
  retraits      Retrait[]
  decodeurs     Decodeur[]
  objectifs        Objectif[]
  objectifsPdv     ObjectifPdv[]
  stocksAccessoire StockAccessoire[]
  ventesAccessoire VenteAccessoire[]
  retoursAccessoire RetourDefectueux[]
  ventesKit         VenteKit[]
  credit            Credit?
  arretes           ArreteSolde[]
  installations     Installation[]
  gapKits           GapKit[]
  ventesParabole    VenteParabole[]
}

model Formule {
  id            String   @id @default(cuid())
  code          String   @unique
  nomCommercial String
  prixMateriel  Float
  prixFormule   Float
  // Statut: ACTIF | INACTIF
  statut        String   @default("ACTIF")

  abonnes       Abonne[]
  encaissements Encaissement[]
}

model Abonne {
  id           String       @id @default(cuid())
  numAbonne    String       @unique
  nom          String
  prenom       String
  tel1         String
  tel2         String?
  formuleId    String
  decodeurId   String?
  pdvId        String
  dateEcheance DateTime
  // AbonneStatut: ACTIF | ECHU | SUSPENDU | RESILIE
  statut       String       @default("ACTIF")
  canalReabo   String?
  numeroContrat   String?
  dateProchainRdv DateTime?

  formule       Formule        @relation(fields: [formuleId], references: [id])
  pdv           PDV            @relation(fields: [pdvId], references: [id])
  decodeur      Decodeur?      @relation(fields: [decodeurId], references: [id])
  encaissements Encaissement[]
}

model Decodeur {
  id          String         @id @default(cuid())
  numSerie    String         @unique
  // DecodeurType: Z4 | GLOBAZ | G11
  type        String
  // DecodeurStatut: EN_STOCK_ENTREPOT | EN_STOCK_PDV | VENDU | IMMOBILISE | DEFECTUEUX
  statut      String         @default("EN_STOCK_ENTREPOT")
  entrepotId  String?
  pdvId       String?
  dateEntree  DateTime       @default(now())

  entrepot Entrepot? @relation(fields: [entrepotId], references: [id])
  pdv      PDV?      @relation(fields: [pdvId], references: [id])
  abonnes  Abonne[]
}

model Encaissement {
  id           String             @id @default(cuid())
  abonneId     String
  pdvId        String
  userId       String
  // NatureEncaissement: RECRUTEMENT | REABONNEMENT | MIGRATION | IMPAYE
  nature       String
  formuleId    String
  nbMois       Int
  montantTotal Float
  montantRecu  Float
  monnaie      String             @default("XOF")
  // ModePaiement: ESPECE | WAVE | ORANGE_MONEY | CHEQUE | VIREMENT
  modePaiement String
  // JSON sérialisé en texte (SQLite ne supporte pas le type Json natif).
  options      String             @default("{}")
  date         DateTime
  recuNumero   String
  // Clé d'idempotence pour l'import CANAL (évite les doublons au ré-import).
  importKey    String?            @unique
  createdAt    DateTime           @default(now())

  abonne  Abonne  @relation(fields: [abonneId], references: [id])
  pdv     PDV     @relation(fields: [pdvId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  formule Formule @relation(fields: [formuleId], references: [id])
}

model Banque {
  id          String     @id @default(cuid())
  nom         String
  numCompte   String
  // BanqueType: BANQUE | MOBILE_MONEY | WAVE
  type        String
  soldeActuel Float      @default(0)
}

model Versement {
  id            String          @id @default(cuid())
  pdvId         String
  montant       Float
  banqueId      String
  dateVersement DateTime
  periode       String
  libelle       String
  numBordereau  String
  photoBordereau String?
  // VersementStatut: ENATTENTE | VALIDE | REJETE
  statut        String          @default("ENATTENTE")
  motifRejet    String?
  valideParId   String?
  createdAt     DateTime        @default(now())

  pdv        PDV   @relation(fields: [pdvId], references: [id])
  validePar  User? @relation("ValideParVersement", fields: [valideParId], references: [id])
}

model Retrait {
  id            String          @id @default(cuid())
  pdvId         String
  montant       Float
  banqueId      String
  dateVersement DateTime
  periode       String
  libelle       String
  numBordereau  String
  photoBordereau String?
  // VersementStatut: ENATTENTE | VALIDE | REJETE
  statut        String          @default("ENATTENTE")
  motifRejet    String?
  valideParId   String?
  createdAt     DateTime        @default(now())

  pdv       PDV   @relation(fields: [pdvId], references: [id])
  validePar User? @relation("ValideParRetrait", fields: [valideParId], references: [id])
}

model RapportActivite {
  id              String         @id @default(cuid())
  date            DateTime
  fichierImporte  String
  montantTotal    Float
  sat             Float
  fibre           Float
  rex             Float
  nbReabo         Int
  caReabo         Float
  nbRecru         Int
  caFormule       Float
  caCreatZ4       Float
  caCreatGZ       Float
  caCreatG11      Float
  caPayech        Float
  caAccessoires   Float
  // StatutMatching: EN_ATTENTE | MATCHE | ECART
  statutMatching  String         @default("EN_ATTENTE")
  importeParId    String
  importeLe       DateTime
  createdAt       DateTime       @default(now())

  importePar User @relation(fields: [importeParId], references: [id])
}

model Entrepot {
  id        String       @id @default(cuid())
  code      String       @unique
  nom       String
  // EntrepotType: PRINCIPAL | SECONDAIRE
  type      String
  capacite  Int
  // Statut: ACTIF | INACTIF
  statut    String       @default("ACTIF")

  decodeurs Decodeur[]
}

model MouvementStock {
  id              String        @id @default(cuid())
  // MouvementType: EN_ENTREPOT_PDV | PDV_PDV | ENTREPOT_ENTREPOT | PDV_ENTREPOT
  type            String
  materiel        String
  sourceId        String
  destinationId   String
  quantite        Int
  numBonLivraison String
  date            DateTime
  // Statut: ACTIF | INACTIF
  statut          String        @default("ACTIF")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  module    String
  ip        String
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  // NotificationType: WARN | OK | URGENT
  type      String
  message   String
  lien      String?
  lu        Boolean          @default(false)
  dismissed Boolean          @default(false)
  createdAt DateTime         @default(now())
}

model Depense {
  id           String   @id @default(cuid())
  date         DateTime
  categorie    String
  motif        String
  montant      Float
  justificatif String?
  createdAt    DateTime @default(now())
}

model Objectif {
  id           String  @id @default(cuid())
  pdvId        String?
  typeObjectif String
  cible        Float
  periode      String

  pdv PDV? @relation(fields: [pdvId], references: [id])
}

model Accessoire {
  id            String  @id @default(cuid())
  code          String  @unique
  nom           String
  prixUnitaire  Float
  stockEntrepot Int     @default(0)
  // Statut: ACTIF | INACTIF
  statut        String  @default("ACTIF")

  stocksReseau StockAccessoire[]
  ventes       VenteAccessoire[]
  retours      RetourDefectueux[]
}

model StockAccessoire {
  id           String @id @default(cuid())
  accessoireId String
  pdvId        String
  quantite     Int    @default(0)

  accessoire Accessoire @relation(fields: [accessoireId], references: [id])
  pdv        PDV        @relation(fields: [pdvId], references: [id])

  @@unique([accessoireId, pdvId])
}

model VenteAccessoire {
  id           String   @id @default(cuid())
  accessoireId String
  pdvId        String
  quantite     Int
  montant      Float
  date         DateTime @default(now())

  accessoire Accessoire @relation(fields: [accessoireId], references: [id])
  pdv        PDV        @relation(fields: [pdvId], references: [id])
}

model RetourDefectueux {
  id           String   @id @default(cuid())
  accessoireId String
  pdvId        String
  quantite     Int
  motif        String
  statut       String   @default("EN_ATTENTE")
  date         DateTime @default(now())

  accessoire Accessoire @relation(fields: [accessoireId], references: [id])
  pdv        PDV        @relation(fields: [pdvId], references: [id])
}

model VenteKit {
  id           String       @id @default(cuid())
  vadPdvId     String
  // DecodeurType: Z4 | GLOBAZ | G11
  decodeurType String
  clientNom    String
  montant      Float
  date         DateTime     @default(now())

  vadPdv PDV @relation(fields: [vadPdvId], references: [id])
}

model Credit {
  id        String   @id @default(cuid())
  pdvId     String   @unique
  plafond   Float    @default(0)
  avoir     Float    @default(0)
  dette     Float    @default(0)
  updatedAt DateTime @updatedAt

  pdv PDV @relation(fields: [pdvId], references: [id])
}

model ArreteSolde {
  id         String   @id @default(cuid())
  pdvId      String
  periode    String
  soldeFige  Float
  dateArrete DateTime @default(now())
  statut     String   @default("SIGNE")

  pdv PDV @relation(fields: [pdvId], references: [id])
}

model Installation {
  id              String    @id @default(cuid())
  pdvId           String
  clientNom       String
  technicien      String
  dateDemande     DateTime  @default(now())
  dateInstallation DateTime?
  statut          String    @default("DEMANDEE")

  pdv PDV @relation(fields: [pdvId], references: [id])
}

/// Barèmes de commission, ÉDITABLES par l'admin (lus depuis la BDD, jamais en
/// dur). unite = "F" (montant fixe par abonné) ou "%" (pourcentage du CA HT).
model ParametreCommission {
  id              String   @id @default(cuid())
  typeCommission  String   @unique
  libelle         String   @default("")
  valeur          Float
  unite           String   @default("F")
  actif           Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

/// Objectifs globaux du distributeur (par an / trimestre / mois éventuel).
model ObjectifDistributeur {
  id           String   @id @default(cuid())
  annee        Int
  trimestre    Int?
  mois         Int?
  formule      String   @default("TOUTES")
  // typeObjectif: RECRUTEMENT | REABONNEMENT
  typeObjectif String
  effectif     Int
  createdById  String?
  createdAt    DateTime @default(now())
}

/// Objectifs par point de vente (par an / mois).
model ObjectifPdv {
  id           String   @id @default(cuid())
  pdvId        String
  annee        Int
  mois         Int
  // typeObjectif: RECRUTEMENT | REABONNEMENT
  typeObjectif String
  effectif     Int
  createdById  String?
  createdAt    DateTime @default(now())

  pdv PDV @relation(fields: [pdvId], references: [id])

  @@unique([pdvId, annee, mois, typeObjectif])
}

/// Suivi des kits incomplets après une vente (Gap Kit).
model GapKit {
  id                String   @id @default(cuid())
  pdvId             String
  clientNom         String?
  numAbonne         String?
  kitVendu          String
  elementsManquants String
  // statut: EN_ATTENTE | REGULARISE
  statut            String   @default("EN_ATTENTE")
  date              DateTime @default(now())

  pdv PDV @relation(fields: [pdvId], references: [id])
}

/// Suivi des ventes de paraboles par PDV.
model VenteParabole {
  id             String   @id @default(cuid())
  pdvId          String
  quantiteVendue Int      @default(0)
  quantiteStock  Int      @default(0)
  technicien     String?
  date           DateTime @default(now())

  pdv PDV @relation(fields: [pdvId], references: [id])
}

/// Journal des événements de sécurité (connexions, blocages, accès refusés).
model SecurityEvent {
  id         String   @id @default(cuid())
  // type: LOGIN_FAILED | LOGIN_LOCKED | LOGIN_OK | ACCESS_DENIED
  type       String
  identifier String?
  ip         String   @default("")
  message    String?
  createdAt  DateTime @default(now())

  @@index([type, createdAt])
  @@index([identifier, createdAt])
}

model RetourRpe {
  id           String   @id @default(cuid())
  numAbonne    String
  nom          String
  prenom       String
  tel          String?
  formule      String?
  pdv          String?
  agent        String?
  joint        String   @default("")
  installation String   @default("")
  satisfaction String   @default("")
  mycanal      String   @default("")
  netflix      String   @default("")
  progrFidel   String   @default("")
  score        Int?
  commentaire  String?
  statut       String   @default("EN_COURS")
  date         DateTime @default(now())
}
