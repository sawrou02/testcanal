# --- SENDISTRI backend — variables d'environnement ---

# HORS-LIGNE (Windows, par défaut) : base SQLite locale
DATABASE_URL="file:./sendistri.db"

# EN LIGNE (cloud) : remplacer par l'URL PostgreSQL de Neon, ex.
# DATABASE_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Clé de signature des connexions. EN LIGNE : Render en génère une automatiquement.
JWT_SECRET="change-moi-par-une-longue-chaine-unique"

# Port du serveur (Render l'injecte automatiquement en ligne)
PORT=3000

# Origine autorisée (le site frontend). EN LIGNE : ton URL Vercel.
WEB_ORIGIN="http://localhost:5173"

# Dossier des fichiers uploadés (EN LIGNE : disque persistant Render)
# UPLOADS_DIR="/var/data/uploads"
